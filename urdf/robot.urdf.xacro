<?xml version="1.0"?>
<!--
  Top-level Husky A200-0876 description.

  This is the single entry point that composes all platform, accessory,
  sensor and manipulator modules. Modify this file to add/remove
  payloads rather than editing the sub-macros directly.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="a200_0876">

  <!-- =========================================================== -->
  <!--  ARGUMENTS                                                   -->
  <!-- =========================================================== -->
  <xacro:arg name="use_gazebo"         default="false"/>
  <xacro:arg name="use_ros2_control"   default="true"/>
  <xacro:arg name="serial_port"        default="/dev/clearpath/prolific"/>

  <!-- =========================================================== -->
  <!--  COMMON                                                      -->
  <!-- =========================================================== -->
  <xacro:include filename="$(find husky_description)/urdf/common/materials.xacro"/>

  <!-- =========================================================== -->
  <!--  PLATFORM (A200 chassis + wheels + inertial)                 -->
  <!-- =========================================================== -->
  <xacro:include filename="$(find husky_description)/urdf/platform/a200.urdf.xacro"/>
  <xacro:a200_platform use_gazebo="$(arg use_gazebo)"/>

  <!-- =========================================================== -->
  <!--  ACCESSORIES                                                 -->
  <!-- =========================================================== -->
  <!-- Front bumper -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/bumper.urdf.xacro"/>
  <xacro:husky_bumper prefix="front" parent="front_bumper_mount"/>

  <!-- Dual-arm bulkhead (custom payload deck for this robot) -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/dual_arm_bulkhead.urdf.xacro"/>
  <xacro:dual_arm_bulkhead parent="base_link" xyz="0 0 0.224" rpy="0 0 0"/>

  <!-- Custom camera mount on top of the bulkhead -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/camera_mount.urdf.xacro"/>
  <xacro:camera_mount prefix="camera_mount" parent="dual_arm_bulkhead_link" xyz="0.20545 0.005 0.19744" rpy="0 0 0"/>

  <!-- FR12 bracket on top of camera mount -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/fr12_bracket.urdf.xacro"/>
  <xacro:fr12_bracket prefix="fr12_0" parent="camera_mount_link" xyz="0.125 -0.003 0.232" rpy="0 0 0"/>

  <!-- 2XL430 servo (tilt axis) on top of FR12 bracket -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/dynamixel_2xl430.urdf.xacro"/>
  <xacro:dynamixel_2xl430 prefix="tilt_0" parent="fr12_0_link" xyz="0 0 0" rpy="0 0 0"/>

  <!-- FR12-H104 bracket on the pan output of the 2XL430 -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/fr12_h104_pan.urdf.xacro"/>
  <xacro:fr12_h104_pan prefix="pan_0" parent="tilt_0_link" xyz="0.025 0 0" rpy="0 0 0"/>

  <!-- Neck camera holder -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/neck_camera_holder.urdf.xacro"/>
  <xacro:neck_camera_holder prefix="neck_0" parent="pan_0_link" xyz="0.038 -0.0025 0.034" rpy="0 0 0"/>

  

  <!-- =========================================================== -->
  <!--  MANIPULATORS                                                -->
  <!-- =========================================================== -->
  <xacro:include filename="$(find husky_description)/urdf/manipulators/ur5e.urdf.xacro"/>
  <xacro:include filename="$(find husky_description)/urdf/manipulators/robotiq_2f_85.urdf.xacro"/>

  <!-- Left arm (arm_0) -->
  <xacro:ur5e_arm prefix="arm_0" parent="dual_arm_bulkhead_link"
                  xyz="0.1225  0.14891 0.13371" rpy="0.785398 0.0 3.14159"/>
  <xacro:robotiq_2f_85 prefix="arm_0_gripper" parent="arm_0_tool0"/>

  <!-- Right arm (arm_1) -->
  <xacro:ur5e_arm prefix="arm_1" parent="dual_arm_bulkhead_link"
                  xyz="0.1225 -0.14891 0.13371" rpy="0.785398 0.0 0.0"/>
  <xacro:robotiq_2f_85 prefix="arm_1_gripper" parent="arm_1_tool0"/>

  <!-- =========================================================== -->
  <!--  SENSORS                                                     -->
  <!-- =========================================================== -->
  <!-- 3D Lidar on bulkhead -->
  <xacro:include filename="$(find husky_description)/urdf/sensors/velodyne_vlp16.urdf.xacro"/>
  <xacro:velodyne_vlp16 prefix="lidar3d_0" parent="dual_arm_bulkhead_link"
                        xyz="0.35545 0.0 0.19744" rpy="0 0 0"
                        topic="/sensors/lidar3d_0/scan"
                        use_gazebo="$(arg use_gazebo)"/>

  <!-- Wrist mounts + Fath pivots + RealSense cameras (one chain per arm) -->
  <xacro:include filename="$(find husky_description)/urdf/accessories/wrist_mount.urdf.xacro"/>
  <xacro:include filename="$(find husky_description)/urdf/accessories/fath_pivot_mount.urdf.xacro"/>
  <xacro:include filename="$(find husky_description)/urdf/sensors/realsense_d435.urdf.xacro"/>

  <!-- Left arm camera -->
  <xacro:wrist_mount prefix="arm_0_wrist_mount" parent="arm_0_tool0"
                    xyz="0 0 0" rpy="0 0 0"
                    mesh_rpy="0 1.5708 -1.5708"/>
  <!-- Alignment frame: lives in the rotated frame so children's poses stay valid -->
  <link name="arm_0_wrist_mount_aligned"/>
  <joint name="arm_0_wrist_mount_aligned_joint" type="fixed">
    <parent link="arm_0_wrist_mount_link"/>
    <child  link="arm_0_wrist_mount_aligned"/>
    <origin xyz="0 0 0" rpy="0 1.5708 -1.5708"/>
  </joint>
  <xacro:fath_pivot_mount prefix="arm_0_pivot" parent="arm_0_wrist_mount_aligned"
                          angle="${pi/12}"
                          xyz="-0.01615 0 0.05842" rpy="0 0 3.14159"/>
  <xacro:realsense_d435 prefix="camera_0" parent="arm_0_pivot_mount"
                        xyz="0 0 0" rpy="0 0 0"
                        topic="/sensors/camera_0"
                        use_gazebo="$(arg use_gazebo)"
                        show_bracket="false"/>

  <!-- Right arm camera -->
  <xacro:wrist_mount prefix="arm_1_wrist_mount" parent="arm_1_tool0"
                    xyz="0 0 0" rpy="0 0 0"
                    mesh_rpy="0 1.5708 1.5708"/>
  <!-- Alignment frame -->
  <link name="arm_1_wrist_mount_aligned"/>
  <joint name="arm_1_wrist_mount_aligned_joint" type="fixed">
    <parent link="arm_1_wrist_mount_link"/>
    <child  link="arm_1_wrist_mount_aligned"/>
    <origin xyz="0 0 0" rpy="0 1.5708 1.5708"/>
  </joint>
  <xacro:fath_pivot_mount prefix="arm_1_pivot" parent="arm_1_wrist_mount_aligned"
                          angle="${pi/12}"
                          xyz="-0.01615 0 0.05842" rpy="0 0 3.14159"/>
  <xacro:realsense_d435 prefix="camera_1" parent="arm_1_pivot_mount"
                        xyz="0 0 0" rpy="0 0 0"
                        topic="/sensors/camera_1"
                        use_gazebo="$(arg use_gazebo)"
                        show_bracket="false"/>

  <xacro:realsense_d435 prefix="camera_2" parent="neck_0_link"
                        xyz="0.01 0.0 -0.025" rpy="0 0 0"
                        topic="/sensors/camera_2"
                        use_gazebo="$(arg use_gazebo)"
                        show_bracket="false"/>

  <!-- IMU -->
  <xacro:include filename="$(find husky_description)/urdf/sensors/imu.urdf.xacro"/>
  <xacro:imu_sensor prefix="imu_0" parent="base_link"
                    xyz="0 0 0" rpy="0 0 0"
                    topic="/sensors/imu_0/data"
                    use_gazebo="$(arg use_gazebo)"/>


  <!-- GPS -->
  <xacro:include filename="$(find husky_description)/urdf/sensors/gps.urdf.xacro"/>
  <xacro:gps_sensor prefix="gps_0" parent="dual_arm_bulkhead_link"
                    xyz="-0.20 0 0.27617" rpy="0 0 0"
                    topic="/sensors/gps_0/navsat"
                    use_gazebo="$(arg use_gazebo)"/>

  <!-- =========================================================== -->
  <!--  ROS2 CONTROL                                                -->
  <!-- =========================================================== -->
  <xacro:if value="$(arg use_ros2_control)">
    <xacro:include filename="$(find husky_description)/urdf/control/a200_ros2_control.xacro"/>
    <xacro:a200_ros2_control serial_port="$(arg serial_port)"/>
  </xacro:if>

</robot>
