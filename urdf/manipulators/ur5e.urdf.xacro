<?xml version="1.0"?>
<!--
  Universal Robots UR5e arm macro.

  NOTE: for *calibrated* kinematics you should feed per-robot values
  from a yaml produced by the UR_Calibration tool. These defaults
  match the nominal UR5e and are fine for visualization / simulation.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="ur5e_arm" params="prefix parent xyz rpy">

    <!-- ======== MESH HELPERS ======== -->
    <xacro:property name="ur_mesh_visual"
                    value="package://husky_description/meshes/ur_description/meshes/ur5e/visual"/>
    <xacro:property name="ur_mesh_collision"
                    value="package://husky_description/meshes/ur_description/meshes/ur5e/collision"/>

    <!-- ======== BASE ATTACHMENT ======== -->
    <link name="${prefix}_base_link"/>
    <joint name="${prefix}_base_joint" type="fixed">
      <origin rpy="${rpy}" xyz="${xyz}"/>
      <parent link="${parent}"/>
      <child  link="${prefix}_base_link"/>
    </joint>

    <!-- ======== BASE LINK INERTIA ======== -->
    <link name="${prefix}_base_link_inertia">
      <visual>
        <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/base.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/base.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="4.0"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="0.00443333156" ixy="0.0" ixz="0.0"
                 iyy="0.00443333156" iyz="0.0"
                 izz="0.0072"/>
      </inertial>
    </link>
    <joint name="${prefix}_base_link-base_link_inertia" type="fixed">
      <!-- ROS REP-103 forward-X vs UR internal backward-X: rotate pi around Z -->
      <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
      <parent link="${prefix}_base_link"/>
      <child  link="${prefix}_base_link_inertia"/>
    </joint>

    <!-- ======== SHOULDER ======== -->
    <link name="${prefix}_shoulder_link">
      <visual>
        <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/shoulder.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/shoulder.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="3.761"/>
        <origin rpy="${pi/2} 0 0" xyz="0.0 -0.00193 -0.02561"/>
        <inertia ixx="0.0070021" ixy="7.3e-07" ixz="-1.053e-05"
                 iyy="0.00648091" iyz="0.00049994"
                 izz="0.00657286"/>
      </inertial>
    </link>
    <joint name="${prefix}_shoulder_pan_joint" type="revolute">
      <parent link="${prefix}_base_link_inertia"/>
      <child  link="${prefix}_shoulder_link"/>
      <origin rpy="0 0 0" xyz="0 0 0.1625"/>
      <axis   xyz="0 0 1"/>
      <limit effort="150.0" lower="${-2*pi}" upper="${2*pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== UPPER ARM ======== -->
    <link name="${prefix}_upper_arm_link">
      <visual>
        <origin rpy="${pi/2} 0 ${-pi/2}" xyz="0 0 0.138"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/upperarm.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 ${-pi/2}" xyz="0 0 0.138"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/upperarm.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="8.058"/>
        <origin rpy="0 0 0" xyz="-0.2125 0.0 0.11336"/>
        <inertia ixx="0.01505885" ixy="-5.4e-05" ixz="5.63e-06"
                 iyy="0.33388086" iyz="-1.81e-06"
                 izz="0.33247207"/>
      </inertial>
    </link>
    <joint name="${prefix}_shoulder_lift_joint" type="revolute">
      <parent link="${prefix}_shoulder_link"/>
      <child  link="${prefix}_upper_arm_link"/>
      <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
      <axis   xyz="0 0 1"/>
      <limit effort="150.0" lower="${-2*pi}" upper="${2*pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== FOREARM ======== -->
    <link name="${prefix}_forearm_link">
      <visual>
        <origin rpy="${pi/2} 0 ${-pi/2}" xyz="0 0 0.007"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/forearm.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 ${-pi/2}" xyz="0 0 0.007"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/forearm.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.846"/>
        <origin rpy="0 0 0" xyz="-0.2422 0.0 0.0265"/>
        <inertia ixx="0.00399632" ixy="-1.365e-05" ixz="0.00137272"
                 iyy="0.07879254" iyz="-6.6e-06"
                 izz="0.0784851"/>
      </inertial>
    </link>
    <joint name="${prefix}_elbow_joint" type="revolute">
      <parent link="${prefix}_upper_arm_link"/>
      <child  link="${prefix}_forearm_link"/>
      <origin rpy="0 0 0" xyz="-0.425 0 0"/>
      <axis   xyz="0 0 1"/>
      <limit effort="150.0" lower="${-pi}" upper="${pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== WRIST 1 ======== -->
    <link name="${prefix}_wrist_1_link">
      <visual>
        <origin rpy="${pi/2} 0 0" xyz="0 0 -0.127"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/wrist1.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0" xyz="0 0 -0.127"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/wrist1.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.37"/>
        <origin rpy="${pi/2} 0 0" xyz="0.0 -0.01634 -0.0018"/>
        <inertia ixx="0.00165491" ixy="-2.82e-06" ixz="-4.38e-06"
                 iyy="0.00135962" iyz="0.00010157"
                 izz="0.00126279"/>
      </inertial>
    </link>
    <joint name="${prefix}_wrist_1_joint" type="revolute">
      <parent link="${prefix}_forearm_link"/>
      <child  link="${prefix}_wrist_1_link"/>
      <origin rpy="0 0 0" xyz="-0.3922 0 0.1333"/>
      <axis   xyz="0 0 1"/>
      <limit effort="28.0" lower="${-2*pi}" upper="${2*pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== WRIST 2 ======== -->
    <link name="${prefix}_wrist_2_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 -0.0997"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/wrist2.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 -0.0997"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/wrist2.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.3"/>
        <origin rpy="${-pi/2} 0 0" xyz="0.0 0.01634 -0.0018"/>
        <inertia ixx="0.00135617" ixy="-2.74e-06" ixz="4.44e-06"
                 iyy="0.00127827" iyz="-5.048e-05"
                 izz="0.00096614"/>
      </inertial>
    </link>
    <joint name="${prefix}_wrist_2_joint" type="revolute">
      <parent link="${prefix}_wrist_1_link"/>
      <child  link="${prefix}_wrist_2_link"/>
      <origin rpy="${pi/2} 0 0" xyz="0 -0.0997 0"/>
      <axis   xyz="0 0 1"/>
      <limit effort="28.0" lower="${-2*pi}" upper="${2*pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== WRIST 3 ======== -->
    <link name="${prefix}_wrist_3_link">
      <visual>
        <origin rpy="${pi/2} 0 0" xyz="0 0 -0.0989"/>
        <geometry>
          <mesh filename="${ur_mesh_visual}/wrist3.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="${pi/2} 0 0" xyz="0 0 -0.0989"/>
        <geometry>
          <mesh filename="${ur_mesh_collision}/wrist3.stl"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.365"/>
        <origin rpy="0 0 0" xyz="0.0 0.0 -0.001159"/>
        <inertia ixx="0.00018694" ixy="6e-08" ixz="-1.7e-07"
                 iyy="0.00018908" iyz="-9.2e-07"
                 izz="0.00025756"/>
      </inertial>
    </link>
    <joint name="${prefix}_wrist_3_joint" type="revolute">
      <parent link="${prefix}_wrist_2_link"/>
      <child  link="${prefix}_wrist_3_link"/>
      <origin rpy="${pi/2} ${pi} ${pi}" xyz="0 0.0996 0"/>
      <axis   xyz="0 0 1"/>
      <limit effort="28.0" lower="${-2*pi}" upper="${2*pi}" velocity="${pi}"/>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- ======== TOOL / FLANGE / FT FRAMES ======== -->
    <link name="${prefix}_ft_frame"/>
    <joint name="${prefix}_wrist_3_link-ft_frame" type="fixed">
      <parent link="${prefix}_wrist_3_link"/>
      <child  link="${prefix}_ft_frame"/>
      <origin rpy="${pi} 0 0" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}_base"/>
    <joint name="${prefix}_base_link-base_fixed_joint" type="fixed">
      <!-- UR 'Base' coordinate system: rotated by pi around Z relative to ROS base_link -->
      <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
      <parent link="${prefix}_base_link"/>
      <child  link="${prefix}_base"/>
    </joint>

    <link name="${prefix}_flange"/>
    <joint name="${prefix}_wrist_3-flange" type="fixed">
      <parent link="${prefix}_wrist_3_link"/>
      <child  link="${prefix}_flange"/>
      <origin rpy="0 ${-pi/2} ${-pi/2}" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}_tool0"/>
    <joint name="${prefix}_flange-tool0" type="fixed">
      <!-- default toolframe: X+ left, Y+ up, Z+ front -->
      <origin rpy="${pi/2} 0 ${pi/2}" xyz="0 0 0"/>
      <parent link="${prefix}_flange"/>
      <child  link="${prefix}_tool0"/>
    </joint>

  </xacro:macro>
</robot>
