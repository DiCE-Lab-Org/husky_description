<?xml version="1.0"?>
<!--
  Robotiq 2F-85 parallel gripper macro.

  All right-side / inner / finger-tip joints mimic the single driver
  joint "${prefix}_left_knuckle_joint".
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="robotiq_2f_85" params="prefix parent">

    <xacro:property name="mesh_visual"
                    value="package://husky_description/meshes/robotiq_description/meshes/visual/2f_85"/>
    <xacro:property name="mesh_collision"
                    value="package://husky_description/meshes/robotiq_description/meshes/collision/2f_85"/>

    <!-- ========== BASE ========== -->
    <link name="${prefix}_robotiq_85_base_link">
      <visual>
        <geometry><mesh filename="${mesh_visual}/robotiq_base.dae"/></geometry>
      </visual>
      <collision>
        <geometry><mesh filename="${mesh_collision}/robotiq_base.stl"/></geometry>
      </collision>
      <inertial>
        <origin rpy="0 0 0" xyz="0.0 2.274e-05 0.03232288"/>
        <mass value="0.66320197"/>
        <inertia ixx="5.1617816e-04" ixy="2.936e-8"   ixz="0.0"
                 iyy="5.8802208e-04" iyz="-3.2296e-7"
                 izz="3.9462776e-04"/>
      </inertial>
    </link>
    <joint name="${prefix}_robotiq_85_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}_robotiq_85_base_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <!-- ========== KNUCKLE MACRO ========== -->
    <xacro:macro name="knuckle" params="side sign">
      <link name="${prefix}_robotiq_85_${side}_knuckle_link">
        <visual>
          <geometry><mesh filename="${mesh_visual}/${side}_knuckle.dae"/></geometry>
        </visual>
        <collision>
          <geometry><mesh filename="${mesh_collision}/${side}_knuckle.stl"/></geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${sign*0.01213197} 0.0002 -0.00058647"/>
          <mass value="0.01384773208"/>
          <inertia ixx="3.5232e-7" ixy="0.0" ixz="${sign*1.1744e-7}"
                   iyy="2.31944e-6" iyz="0"
                   izz="2.23136e-6"/>
        </inertial>
      </link>
    </xacro:macro>
    <xacro:knuckle side="left"  sign="1"/>
    <xacro:knuckle side="right" sign="-1"/>

    <!-- ========== FINGER MACRO ========== -->
    <xacro:macro name="finger" params="side sign">
      <link name="${prefix}_robotiq_85_${side}_finger_link">
        <visual>
          <geometry><mesh filename="${mesh_visual}/${side}_finger.dae"/></geometry>
        </visual>
        <collision>
          <geometry><mesh filename="${mesh_collision}/${side}_finger.stl"/></geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${sign*0.00346899} -0.00079447 0.01867121"/>
          <mass value="0.04260376752"/>
          <inertia ixx="1.385792e-05" ixy="0.0" ixz="${-sign*2.17264e-06}"
                   iyy="1.183208e-05" iyz="0.0"
                   izz="5.19672e-06"/>
        </inertial>
      </link>
    </xacro:macro>
    <xacro:finger side="left"  sign="1"/>
    <xacro:finger side="right" sign="-1"/>

    <!-- ========== INNER KNUCKLE MACRO ========== -->
    <xacro:macro name="inner_knuckle" params="side sign">
      <link name="${prefix}_robotiq_85_${side}_inner_knuckle_link">
        <visual>
          <geometry><mesh filename="${mesh_visual}/${side}_inner_knuckle.dae"/></geometry>
        </visual>
        <collision>
          <geometry><mesh filename="${mesh_collision}/${side}_inner_knuckle.stl"/></geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${sign*0.019} 0.0001 0.0224"/>
          <mass value="0.02969376448"/>
          <inertia ixx="9.5e-06" ixy="0.0" ixz="${-sign*3.95e-06}"
                   iyy="8.69056e-06" iyz="0.0"
                   izz="8.26e-06"/>
        </inertial>
      </link>
    </xacro:macro>
    <xacro:inner_knuckle side="left"  sign="1"/>
    <xacro:inner_knuckle side="right" sign="-1"/>

    <!-- ========== FINGER TIP MACRO ========== -->
    <xacro:macro name="finger_tip" params="side sign">
      <link name="${prefix}_robotiq_85_${side}_finger_tip_link">
        <visual>
          <geometry><mesh filename="${mesh_visual}/${side}_finger_tip.dae"/></geometry>
        </visual>
        <collision>
          <geometry><mesh filename="${mesh_collision}/${side}_finger_tip.stl"/></geometry>
        </collision>
        <inertial>
          <origin rpy="0 0 0" xyz="${-sign*0.01456706} -0.0004 0.01649701"/>
          <mass value="0.04268588744"/>
          <inertia ixx="1.048152e-05" ixy="0.0" ixz="${sign*3.5232e-6}"
                   iyy="1.197888e-05" iyz="0.0"
                   izz="4.22784e-06"/>
        </inertial>
      </link>
    </xacro:macro>
    <xacro:finger_tip side="left"  sign="1"/>
    <xacro:finger_tip side="right" sign="-1"/>

    <!-- ========== JOINTS ========== -->
    <!-- Driver: left knuckle (the only real actuated joint) -->
    <joint name="${prefix}_robotiq_85_left_knuckle_joint" type="revolute">
      <parent link="${prefix}_robotiq_85_base_link"/>
      <child  link="${prefix}_robotiq_85_left_knuckle_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="0.03060114 0.0 0.05490452"/>
      <limit effort="50" lower="0.0" upper="0.8" velocity="0.5"/>
    </joint>

    <joint name="${prefix}_robotiq_85_right_knuckle_joint" type="revolute">
      <parent link="${prefix}_robotiq_85_base_link"/>
      <child  link="${prefix}_robotiq_85_right_knuckle_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="-0.03060114 0.0 0.05490452"/>
      <limit effort="50" lower="-0.8" upper="0.0" velocity="0.5"/>
      <mimic joint="${prefix}_robotiq_85_left_knuckle_joint" multiplier="-1.0" offset="0"/>
    </joint>

    <!-- Fingers rigidly follow their knuckles -->
    <joint name="${prefix}_robotiq_85_left_finger_joint" type="fixed">
      <parent link="${prefix}_robotiq_85_left_knuckle_link"/>
      <child  link="${prefix}_robotiq_85_left_finger_link"/>
      <origin rpy="0 0 0" xyz="0.03152616 0.0 -0.00376347"/>
    </joint>
    <joint name="${prefix}_robotiq_85_right_finger_joint" type="fixed">
      <parent link="${prefix}_robotiq_85_right_knuckle_link"/>
      <child  link="${prefix}_robotiq_85_right_finger_link"/>
      <origin rpy="0 0 0" xyz="-0.03152616 0.0 -0.00376347"/>
    </joint>

    <!-- Inner knuckles (mimic) -->
    <joint name="${prefix}_robotiq_85_left_inner_knuckle_joint" type="continuous">
      <parent link="${prefix}_robotiq_85_base_link"/>
      <child  link="${prefix}_robotiq_85_left_inner_knuckle_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="0.0127 0.0 0.06142"/>
      <mimic joint="${prefix}_robotiq_85_left_knuckle_joint" multiplier="1.0" offset="0"/>
    </joint>
    <joint name="${prefix}_robotiq_85_right_inner_knuckle_joint" type="continuous">
      <parent link="${prefix}_robotiq_85_base_link"/>
      <child  link="${prefix}_robotiq_85_right_inner_knuckle_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="-0.0127 0.0 0.06142"/>
      <mimic joint="${prefix}_robotiq_85_left_knuckle_joint" multiplier="-1.0" offset="0"/>
    </joint>

    <!-- Finger tips (mimic) -->
    <joint name="${prefix}_robotiq_85_left_finger_tip_joint" type="continuous">
      <parent link="${prefix}_robotiq_85_left_finger_link"/>
      <child  link="${prefix}_robotiq_85_left_finger_tip_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="0.00563134 0.0 0.04718515"/>
      <mimic joint="${prefix}_robotiq_85_left_knuckle_joint" multiplier="-1.0" offset="0"/>
    </joint>
    <joint name="${prefix}_robotiq_85_right_finger_tip_joint" type="continuous">
      <parent link="${prefix}_robotiq_85_right_finger_link"/>
      <child  link="${prefix}_robotiq_85_right_finger_tip_link"/>
      <axis   xyz="0 -1 0"/>
      <origin rpy="0 0 0" xyz="-0.00563134 0.0 0.04718515"/>
      <mimic joint="${prefix}_robotiq_85_left_knuckle_joint" multiplier="1.0" offset="0"/>
    </joint>

  </xacro:macro>
</robot>
